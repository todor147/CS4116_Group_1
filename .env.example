# =============================================================================
# EduCoach — environment configuration
# Copy this file to ".env" and fill in your values. NEVER commit a real .env.
# Real host environment variables always override values in this file.
# =============================================================================

# Application environment: "development" or "production"
APP_ENV=development
APP_TIMEZONE=Europe/Dublin

# -----------------------------------------------------------------------------
# Database — Option A: discrete variables (recommended for local / XAMPP)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cs4116_marketplace
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# -----------------------------------------------------------------------------
# Database — Option B: single connection string (handy on PaaS hosts)
# If set, DATABASE_URL takes precedence over the DB_* variables above.
# DATABASE_URL=mysql://user:password@host:3306/database
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# TLS — required by managed providers such as TiDB Cloud or Aiven
# -----------------------------------------------------------------------------
# DB_SSL=true
# DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# -----------------------------------------------------------------------------
# Optional: serve the app from a sub-directory (leave blank for web root)
# -----------------------------------------------------------------------------
# BASE_PATH=
