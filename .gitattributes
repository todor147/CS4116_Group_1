# Normalise line endings. Shell scripts and Docker configs MUST be LF
# so they work inside the Linux container regardless of the OS used to commit.
* text=auto

*.sh            text eol=lf
docker/*        text eol=lf
Dockerfile      text eol=lf
.htaccess       text eol=lf
*.php           text eol=lf
*.css           text eol=lf
*.js            text eol=lf

*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
