# EduCoach — Apache rules
DirectoryIndex index.php
Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block direct web access to server-side directories
    RewriteRule ^(includes|database|logs|docker)/ - [F,L]
</IfModule>

# Block dotfiles (.env, .git, ...) and sensitive file types
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "\.(env|sql|md|log|sh|ini)$">
    Require all denied
</FilesMatch>
